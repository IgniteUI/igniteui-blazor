@page "/IgbTreeComponent"
@using IgniteUI.Blazor.Controls

<PageTitle>IgbTreeComponent</PageTitle>

<h3>IgbTreeComponent</h3>

<div class="controls">
    <div class="control">
        <label>Selection</label>
        <div class="control-box">
            <IgbRadioGroup Alignment="ContentOrientation.Horizontal" @bind-Value="SelectionName">
                <IgbRadio Value="None">None</IgbRadio>
                <IgbRadio Value="Multiple">Multiple</IgbRadio>
                <IgbRadio Value="Cascade">Cascade</IgbRadio>
            </IgbRadioGroup>
        </div>
    </div>

    <div class="control">
        <label>Options</label>
        <div class="control-box switches">
            <IgbSwitch @bind-Checked="SingleBranchExpand">Single branch expand</IgbSwitch>
            <IgbSwitch @bind-Checked="ToggleNodeOnClick">Toggle node on click</IgbSwitch>
        </div>
    </div>
</div>

<div class="component-host">
    <IgbTree class="demo-tree"
             Selection="Selection"
             SingleBranchExpand="SingleBranchExpand"
             ToggleNodeOnClick="ToggleNodeOnClick"
             SelectionChanged="OnSelectionChanged">
        <IgbTreeItem Label="North America" Expanded="true">
            <IgbTreeItem Label="United States" />
            <IgbTreeItem Label="Canada" />
            <IgbTreeItem Label="Mexico" />
        </IgbTreeItem>
        <IgbTreeItem Label="Europe">
            <IgbTreeItem Label="United Kingdom" />
            <IgbTreeItem Label="Germany" />
            <IgbTreeItem Label="Bulgaria" />
        </IgbTreeItem>
        <IgbTreeItem Label="Asia">
            <IgbTreeItem Label="Japan" />
            <IgbTreeItem Label="Singapore" />
        </IgbTreeItem>
    </IgbTree>
</div>

<div class="state">Selected: @Selected</div>

@code {
    /*
     * Ignite UI for Blazor - open-source (MIT) component from IgniteUI.Blazor.Lite.
     * An item template can't modify project files, so do this once per project:
     *
     * 1. Install:   dotnet add package IgniteUI.Blazor.Lite
     * 2. Register (Program.cs):   builder.Services.AddIgniteUIBlazor();
     * 3. _Imports.razor:          @using IgniteUI.Blazor.Controls
     *    (optional here — this file already declares its own @using;
     *    add it to _Imports.razor to share it project-wide)
     * 4. Host page theme (index.html / App.razor / _Host.cshtml):
     *    <link href="_content/IgniteUI.Blazor/themes/light/bootstrap.css" rel="stylesheet" />
     * 5. Blazor Web App (.NET 8+): add an interactive render mode to this page,
     *    e.g. @rendermode InteractiveServer (or InteractiveWebAssembly / InteractiveAuto).
     *
     * Do not mix IgniteUI.Blazor.Lite with the licensed IgniteUI.Blazor package.
     */

    private string SelectionName { get; set; } = "Multiple";
    private TreeSelection Selection => Enum.Parse<TreeSelection>(SelectionName);

    private bool SingleBranchExpand { get; set; }
    private bool ToggleNodeOnClick { get; set; }

    private string Selected { get; set; } = "(none)";

    private void OnSelectionChanged(IgbTreeSelectionEventArgs args)
    {
        var items = args.Detail?.NewSelection;
        Selected = items is null || items.Length == 0
            ? "(none)"
            : string.Join(", ", items.Select(i => i.Label));
    }
}
