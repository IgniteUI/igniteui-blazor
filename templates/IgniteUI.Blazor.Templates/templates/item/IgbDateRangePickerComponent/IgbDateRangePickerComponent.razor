@page "/IgbDateRangePickerComponent"
@using IgniteUI.Blazor.Controls

<PageTitle>IgbDateRangePickerComponent</PageTitle>

<h3>IgbDateRangePickerComponent</h3>

<div class="controls">
    <div class="control">
        <label>Mode</label>
        <div class="control-box">
            <IgbRadioGroup Alignment="ContentOrientation.Horizontal" @bind-Value="ModeName">
                <IgbRadio Value="Dropdown">Dropdown</IgbRadio>
                <IgbRadio Value="Dialog">Dialog</IgbRadio>
            </IgbRadioGroup>
        </div>
    </div>

    <div class="control">
        <label>Options</label>
        <div class="control-box switches">
            <IgbSwitch @bind-Checked="UseTwoInputs">Two inputs</IgbSwitch>
            <IgbSwitch @bind-Checked="UsePredefinedRanges">Predefined ranges</IgbSwitch>
        </div>
    </div>
</div>

<div class="component-host">
    <IgbDateRangePicker class="demo-input"
                        @bind-Value="Range"
                        Mode="Mode"
                        UseTwoInputs="UseTwoInputs"
                        UsePredefinedRanges="UsePredefinedRanges"
                        Label="Trip dates" />
</div>

<div class="state">Range: @RangeText</div>

@code {
    /*
     * Ignite UI for Blazor - open-source (MIT) component from IgniteUI.Blazor.Lite.
     * An item template can't modify project files, so do this once per project:
     *
     * 1. Install:   dotnet add package IgniteUI.Blazor.Lite
     * 2. Register (Program.cs):   builder.Services.AddIgniteUIBlazor();
     * 3. _Imports.razor:          @using IgniteUI.Blazor.Controls
     *    (optional here — this file already declares its own @using;
     *    add it to _Imports.razor to share it project-wide)
     * 4. Host page theme (index.html / App.razor / _Host.cshtml):
     *    <link href="_content/IgniteUI.Blazor/themes/light/bootstrap.css" rel="stylesheet" />
     * 5. Blazor Web App (.NET 8+): add an interactive render mode to this page,
     *    e.g. @rendermode InteractiveServer (or InteractiveWebAssembly / InteractiveAuto).
     *
     * Do not mix IgniteUI.Blazor.Lite with the licensed IgniteUI.Blazor package.
     */

    private IgbDateRangeValue? Range { get; set; }

    private string ModeName { get; set; } = "Dropdown";
    private PickerMode Mode => Enum.Parse<PickerMode>(ModeName);

    private bool UseTwoInputs { get; set; } = true;
    private bool UsePredefinedRanges { get; set; }

    private string RangeText => Range is null
        ? "(none)"
        : $"{Range.Start:d} – {Range.End:d}";
}
