@page "/IgbSnackbarComponent"
@using IgniteUI.Blazor.Controls

<PageTitle>IgbSnackbarComponent</PageTitle>

<h3>IgbSnackbarComponent</h3>

<div class="controls">
    <div class="control">
        <label>Position</label>
        <div class="control-box">
            <IgbRadioGroup Alignment="ContentOrientation.Horizontal" @bind-Value="PositionName">
                <IgbRadio Value="Bottom">Bottom</IgbRadio>
                <IgbRadio Value="Middle">Middle</IgbRadio>
                <IgbRadio Value="Top">Top</IgbRadio>
            </IgbRadioGroup>
        </div>
    </div>

    <div class="control">
        <label>Display time: @DisplayTime ms</label>
        <div class="control-box">
            <IgbSlider class="value-slider" @bind-Value="DisplayTime" Min="1000" Max="8000" Step="500" />
        </div>
    </div>

    <div class="control">
        <label>Options</label>
        <div class="control-box switches">
            <IgbSwitch @bind-Checked="KeepOpen">Keep open</IgbSwitch>
        </div>
    </div>
</div>

<div class="component-host">
    <IgbButton Variant="ButtonVariant.Contained" @onclick="OnShow">Show</IgbButton>
    <IgbButton Variant="ButtonVariant.Outlined" @onclick="OnHide">Hide</IgbButton>
    <IgbButton Variant="ButtonVariant.Outlined" @onclick="OnToggle">Toggle</IgbButton>

    <IgbSnackbar @ref="_snackbar"
                 Position="Position"
                 DisplayTime="DisplayTime"
                 KeepOpen="KeepOpen"
                 ActionText="Undo"
                 Action="OnAction">
        Item moved to archive.
    </IgbSnackbar>
</div>

<div class="state">Last action: @LastAction</div>

@code {
    /*
     * Ignite UI for Blazor - open-source (MIT) component from IgniteUI.Blazor.Lite.
     * An item template can't modify project files, so do this once per project:
     *
     * 1. Install:   dotnet add package IgniteUI.Blazor.Lite
     * 2. Register (Program.cs):   builder.Services.AddIgniteUIBlazor();
     * 3. _Imports.razor:          @using IgniteUI.Blazor.Controls
     * 4. Host page theme (index.html / App.razor / _Host.cshtml):
     *    <link href="_content/IgniteUI.Blazor/themes/light/bootstrap.css" rel="stylesheet" />
     * 5. Blazor Web App (.NET 8+): add an interactive render mode to this page,
     *    e.g. @rendermode InteractiveServer (or InteractiveWebAssembly / InteractiveAuto).
     *
     * Do not mix IgniteUI.Blazor.Lite with the licensed IgniteUI.Blazor package.
     */

    private IgbSnackbar _snackbar = default!;

    private string PositionName { get; set; } = "Bottom";
    private AbsolutePosition Position => Enum.Parse<AbsolutePosition>(PositionName);

    private double DisplayTime { get; set; } = 4000;
    private bool KeepOpen { get; set; }
    private string LastAction { get; set; } = "(none)";

    private async Task OnShow() => await _snackbar.ShowAsync();
    private async Task OnHide() => await _snackbar.HideAsync();
    private async Task OnToggle() => await _snackbar.ToggleAsync();

    private void OnAction(IgbVoidEventArgs args) => LastAction = "Undo clicked";
}
