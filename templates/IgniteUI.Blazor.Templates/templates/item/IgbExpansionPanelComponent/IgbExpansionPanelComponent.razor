@page "/IgbExpansionPanelComponent"
@using IgniteUI.Blazor.Controls

<PageTitle>IgbExpansionPanelComponent</PageTitle>

<h3>IgbExpansionPanelComponent</h3>

<div class="controls">
    <div class="control">
        <label>Indicator position</label>
        <div class="control-box">
            <IgbRadioGroup Alignment="ContentOrientation.Horizontal" @bind-Value="IndicatorPositionName">
                <IgbRadio Value="Start">Start</IgbRadio>
                <IgbRadio Value="End">End</IgbRadio>
                <IgbRadio Value="None">None</IgbRadio>
            </IgbRadioGroup>
        </div>
    </div>

    <div class="control">
        <label>Options</label>
        <div class="control-box switches">
            <IgbSwitch @bind-Checked="Disabled">Disabled</IgbSwitch>
        </div>
    </div>
</div>

<div class="component-host expansion-host">
    <div class="actions">
        <IgbButton Variant="ButtonVariant.Outlined" @onclick="ExpandAll">Expand all</IgbButton>
        <IgbButton Variant="ButtonVariant.Outlined" @onclick="CollapseAll">Collapse all</IgbButton>
    </div>

    <IgbExpansionPanel @ref="_p1" IndicatorPosition="IndicatorPosition" Disabled="Disabled" Open="true">
        <span slot="title">Golden Retriever</span>
        <span slot="subtitle">Medium-large gun dog</span>
        <span>The Golden Retriever is a friendly, intelligent breed that retrieves shot waterfowl during hunting.</span>
    </IgbExpansionPanel>

    <IgbExpansionPanel @ref="_p2" IndicatorPosition="IndicatorPosition" Disabled="Disabled">
        <span slot="title">Labrador Retriever</span>
        <span slot="subtitle">Sporting group</span>
        <span>The Labrador Retriever is an even-tempered, outgoing breed and a popular family companion.</span>
    </IgbExpansionPanel>

    <IgbExpansionPanel @ref="_p3" IndicatorPosition="IndicatorPosition" Disabled="Disabled">
        <span slot="title">German Shepherd</span>
        <span slot="subtitle">Herding group</span>
        <span>The German Shepherd is a working dog known for its intelligence, loyalty and versatility.</span>
    </IgbExpansionPanel>
</div>

<div class="state">Indicator: @IndicatorPositionName &nbsp;|&nbsp; Disabled: @Disabled</div>

@code {
    /*
     * Ignite UI for Blazor - open-source (MIT) component from IgniteUI.Blazor.Lite.
     * An item template can't modify project files, so do this once per project:
     *
     * 1. Install:   dotnet add package IgniteUI.Blazor.Lite
     * 2. Register (Program.cs):   builder.Services.AddIgniteUIBlazor();
     * 3. _Imports.razor:          @using IgniteUI.Blazor.Controls
     * 4. Host page theme (index.html / App.razor / _Host.cshtml):
     *    <link href="_content/IgniteUI.Blazor/themes/light/bootstrap.css" rel="stylesheet" />
     * 5. Blazor Web App (.NET 8+): add an interactive render mode to this page,
     *    e.g. @rendermode InteractiveServer (or InteractiveWebAssembly / InteractiveAuto).
     *
     * Do not mix IgniteUI.Blazor.Lite with the licensed IgniteUI.Blazor package.
     */

    private IgbExpansionPanel _p1 = default!;
    private IgbExpansionPanel _p2 = default!;
    private IgbExpansionPanel _p3 = default!;

    private string IndicatorPositionName { get; set; } = "Start";
    private ExpansionPanelIndicatorPosition IndicatorPosition => Enum.Parse<ExpansionPanelIndicatorPosition>(IndicatorPositionName);

    private bool Disabled { get; set; }

    private async Task ExpandAll()
    {
        foreach (var panel in new[] { _p1, _p2, _p3 })
        {
            await panel.ShowAsync();
        }
    }

    private async Task CollapseAll()
    {
        foreach (var panel in new[] { _p1, _p2, _p3 })
        {
            await panel.HideAsync();
        }
    }
}
