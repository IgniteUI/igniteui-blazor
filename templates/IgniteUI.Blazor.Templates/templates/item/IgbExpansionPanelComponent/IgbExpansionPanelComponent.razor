@page "/IgbExpansionPanelComponent"
@using IgniteUI.Blazor.Controls

<PageTitle>IgbExpansionPanelComponent</PageTitle>

<h3>IgbExpansionPanelComponent</h3>

<div class="component-host">
    <IgbExpansionPanel>
        <span slot="title">Golden Retriever</span>
        <span slot="subtitle">Medium-large gun dog</span>
        <span>The Golden Retriever is a medium-large gun dog that retrieves shot waterfowl during hunting.</span>
