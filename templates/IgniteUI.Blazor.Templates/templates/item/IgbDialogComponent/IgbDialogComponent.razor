@page "/IgbDialogComponent"
@using IgniteUI.Blazor.Controls

<PageTitle>IgbDialogComponent</PageTitle>

<h3>IgbDialogComponent</h3>

<div class="controls">
    <div class="control">
        <label>Options</label>
        <div class="control-box switches">
            <IgbSwitch @bind-Checked="CloseOnOutsideClick">Close on outside click</IgbSwitch>
            <IgbSwitch @bind-Checked="KeepOpenOnEscape">Keep open on escape</IgbSwitch>
        </div>
    </div>
</div>

<div class="component-host">
    <IgbButton Variant="ButtonVariant.Contained" @onclick="OnShow">Show dialog</IgbButton>

    <IgbDialog @ref="_dialog"
               Title="Delete item"
               CloseOnOutsideClick="CloseOnOutsideClick"
               KeepOpenOnEscape="KeepOpenOnEscape"
               Closed="OnClosed">
        <p>Are you sure you want to delete this item? This action cannot be undone.</p>
        <IgbButton slot="footer" Variant="ButtonVariant.Flat" @onclick="@(() => Close("Cancelled"))">Cancel</IgbButton>
        <IgbButton slot="footer" Variant="ButtonVariant.Contained" @onclick="@(() => Close("Deleted"))">Delete</IgbButton>
    </IgbDialog>
</div>

<div class="state">Last result: @LastResult</div>

@code {
    /*
     * Ignite UI for Blazor - open-source (MIT) component from IgniteUI.Blazor.Lite.
     * An item template can't modify project files, so do this once per project:
     *
     * 1. Install:   dotnet add package IgniteUI.Blazor.Lite
     * 2. Register (Program.cs):   builder.Services.AddIgniteUIBlazor();
     * 3. _Imports.razor:          @using IgniteUI.Blazor.Controls
     * 4. Host page theme (index.html / App.razor / _Host.cshtml):
     *    <link href="_content/IgniteUI.Blazor/themes/light/bootstrap.css" rel="stylesheet" />
     * 5. Blazor Web App (.NET 8+): add an interactive render mode to this page,
     *    e.g. @rendermode InteractiveServer (or InteractiveWebAssembly / InteractiveAuto).
     *
     * Do not mix IgniteUI.Blazor.Lite with the licensed IgniteUI.Blazor package.
     */

    private IgbDialog _dialog = default!;

    private bool CloseOnOutsideClick { get; set; }
    private bool KeepOpenOnEscape { get; set; }
    private string LastResult { get; set; } = "(none)";

    private async Task OnShow()
    {
        // A second Esc lets the browser force-close the native dialog without the
        // component clearing its open state, leaving the backdrop stuck. Hiding
        // first resets that stale state; it is a no-op when already closed.
        await _dialog.HideAsync();
        await _dialog.ShowAsync();
    }

    private async Task Close(string result)
    {
        LastResult = result;
        await _dialog.HideAsync();
    }

    private void OnClosed(IgbVoidEventArgs args)
    {
        if (LastResult == "(none)")
        {
            LastResult = "Dismissed";
        }
    }
}
