@page "/IgbListComponent"
@using IgniteUI.Blazor.Controls

<PageTitle>IgbListComponent</PageTitle>

<h3>IgbListComponent</h3>

<div class="controls">
    <div class="control">
        <label>Filter</label>
        <div class="control-box">
            <IgbInput class="filter-input" @bind-Value="Filter" Placeholder="Search contacts" />
        </div>
    </div>

    <div class="control">
        <label>Options</label>
        <div class="control-box switches">
            <IgbSwitch @bind-Checked="ShowAvatars">Show avatars</IgbSwitch>
        </div>
    </div>
</div>

<div class="component-host">
    <IgbList class="contacts">
        <IgbListHeader>Contacts</IgbListHeader>
        @foreach (var c in Filtered)
        {
            <IgbListItem Selected="@(c.Name == SelectedName)" @onclick="@(() => SelectedName = c.Name)">
                @if (ShowAvatars)
                {
                    <IgbAvatar slot="start" Initials="@c.Initials" Shape="AvatarShape.Circle" />
                }
                <span slot="title">@c.Name</span>
                <span slot="subtitle">@c.Phone</span>
            </IgbListItem>
        }
    </IgbList>
</div>

<div class="state">Showing @Filtered.Count of @Contacts.Count &nbsp;|&nbsp; Selected: @(SelectedName ?? "(none)")</div>

@code {
    /*
     * Ignite UI for Blazor - open-source (MIT) component from IgniteUI.Blazor.Lite.
     * An item template can't modify project files, so do this once per project:
     *
     * 1. Install:   dotnet add package IgniteUI.Blazor.Lite
     * 2. Register (Program.cs):   builder.Services.AddIgniteUIBlazor();
     * 3. _Imports.razor:          @using IgniteUI.Blazor.Controls
     *    (optional here — this file already declares its own @using;
     *    add it to _Imports.razor to share it project-wide)
     * 4. Host page theme (index.html / App.razor / _Host.cshtml):
     *    <link href="_content/IgniteUI.Blazor/themes/light/bootstrap.css" rel="stylesheet" />
     * 5. Blazor Web App (.NET 8+): add an interactive render mode to this page,
     *    e.g. @rendermode InteractiveServer (or InteractiveWebAssembly / InteractiveAuto).
     *
     * Do not mix IgniteUI.Blazor.Lite with the licensed IgniteUI.Blazor package.
     */

    private string Filter { get; set; } = string.Empty;
    private bool ShowAvatars { get; set; } = true;
    private string? SelectedName { get; set; }

    private List<Contact> Contacts { get; } = new()
    {
        new("Terrance Orta", "770-504-2217", "TO"),
        new("Richard Mahoney", "423-676-2869", "RM"),
        new("Donna Price", "859-496-2817", "DP"),
        new("Lisa Landers", "901-747-3428", "LL"),
        new("Dorothy Spencer", "573-394-9254", "DS")
    };

    private List<Contact> Filtered => Contacts
        .Where(c => string.IsNullOrEmpty(Filter) || c.Name.Contains(Filter, StringComparison.OrdinalIgnoreCase))
        .ToList();

    private record Contact(string Name, string Phone, string Initials);
}
