@page "/IgbGridComponent"
@using IgniteUI.Blazor.Controls

<PageTitle>IgbGridComponent</PageTitle>

<h3>IgbGridComponent</h3>

<div class="controls">
    <div class="control">
        <label>Options</label>
        <div class="control-box switches">
            <IgbSwitch @bind-Checked="InStockOnly">In stock only</IgbSwitch>
        </div>
    </div>
</div>

<div class="grid-host">
    <IgbGridLite class="demo-grid" TItem="Product" Data="@Visible">
        <IgbGridLiteColumn Field="@nameof(Product.Name)" Header="Product"
                           DataType="GridLiteColumnDataType.String" Sortable Filterable Resizable />
        <IgbGridLiteColumn Field="@nameof(Product.Category)" Header="Category"
                           DataType="GridLiteColumnDataType.String" Sortable Filterable />
        <IgbGridLiteColumn Field="@nameof(Product.Price)" Header="Price"
                           DataType="GridLiteColumnDataType.Number" Sortable />
        <IgbGridLiteColumn Field="@nameof(Product.Released)" Header="Released"
                           DataType="GridLiteColumnDataType.Date" Sortable />
        <IgbGridLiteColumn Field="@nameof(Product.InStock)" Header="In stock"
                           DataType="GridLiteColumnDataType.Boolean" Sortable />
    </IgbGridLite>
</div>

<div class="state">Showing @Visible.Count of @Products.Count products</div>

@code {
    /*
     * Ignite UI Grid Lite setup (open-source, MIT — IgniteUI.Blazor.GridLite).
     * An item template can't modify project files, so do this once per project:
     *
     * 1. Install:   dotnet add package IgniteUI.Blazor.GridLite
     * 2. Register (Program.cs):   builder.Services.AddIgniteUIBlazor();
     * 3. _Imports.razor:          @using IgniteUI.Blazor.Controls
     *    (optional here — this file already declares its own @using;
     *    add it to _Imports.razor to share it project-wide)
     * 4. Host page theme (index.html / App.razor / _Host.cshtml):
     *    <link href="_content/IgniteUI.Blazor.GridLite/css/themes/light/bootstrap.css" rel="stylesheet" />
     * 5. Blazor Web App (.NET 8+): add an interactive render mode to this page,
     *    e.g. @rendermode InteractiveServer (or InteractiveWebAssembly / InteractiveAuto).
     */

    private bool InStockOnly { get; set; }

    private List<Product> Visible => InStockOnly
        ? Products.Where(p => p.InStock).ToList()
        : Products;

