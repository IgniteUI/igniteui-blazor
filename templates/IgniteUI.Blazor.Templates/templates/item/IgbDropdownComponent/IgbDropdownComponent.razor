@page "/IgbDropdownComponent"
@using IgniteUI.Blazor.Controls

<PageTitle>IgbDropdownComponent</PageTitle>

<h3>IgbDropdownComponent</h3>

<div class="controls">
    <div class="control">
        <label>Placement</label>
        <IgbSelect @bind-Value="PlacementName">
            @foreach (var placement in Placements)
            {
                <IgbSelectItem Value="@placement.ToString()">@placement.ToString()</IgbSelectItem>
            }
        </IgbSelect>
    </div>

    <div class="control">
        <label>Options</label>
        <div class="control-box switches">
            <IgbSwitch @bind-Checked="Flip">Flip</IgbSwitch>
            <IgbSwitch @bind-Checked="SameWidth">Same width</IgbSwitch>
        </div>
    </div>
</div>

<div class="component-host">
    <IgbDropdown @ref="_dropdown"
                 Placement="Placement"
                 Flip="Flip"
                 SameWidth="SameWidth"
                 Change="OnChange">
        <IgbButton slot="target">Choose an action</IgbButton>

        <IgbDropdownGroup>
            <span slot="label">Edit</span>
            <IgbDropdownItem Value="edit">
                <IgbIcon @ref="_icon" slot="prefix" IconName="edit" Collection="material"></IgbIcon>
                Edit
                <span slot="suffix">Ctrl+E</span>
            </IgbDropdownItem>
            <IgbDropdownItem Value="duplicate">
                <IgbIcon slot="prefix" IconName="content_copy" Collection="material"></IgbIcon>
                Duplicate
                <span slot="suffix">Ctrl+D</span>
            </IgbDropdownItem>
            <IgbDropdownItem Value="move">
                <IgbIcon slot="prefix" IconName="folder" Collection="material"></IgbIcon>
                Move
                <span slot="suffix">Ctrl+M</span>
            </IgbDropdownItem>
        </IgbDropdownGroup>

        <IgbDropdownGroup>
            <span slot="label">Share</span>
            <IgbDropdownItem Value="copy-link">
                <IgbIcon slot="prefix" IconName="link" Collection="material"></IgbIcon>
                Copy link
                <span slot="suffix">Ctrl+L</span>
            </IgbDropdownItem>
            <IgbDropdownItem Value="share">
                <IgbIcon slot="prefix" IconName="share" Collection="material"></IgbIcon>
                Share
                <span slot="suffix">Ctrl+Shift+S</span>
            </IgbDropdownItem>
            <IgbDropdownItem Value="download">
                <IgbIcon slot="prefix" IconName="download" Collection="material"></IgbIcon>
                Download
                <span slot="suffix">Ctrl+J</span>
            </IgbDropdownItem>
        </IgbDropdownGroup>

        <IgbDropdownGroup>
            <span slot="label">Organize</span>
            <IgbDropdownItem Value="favorite">
                <IgbIcon slot="prefix" IconName="star" Collection="material"></IgbIcon>
                Favorite
                <span slot="suffix">Ctrl+B</span>
            </IgbDropdownItem>
            <IgbDropdownItem Value="archive">
                <IgbIcon slot="prefix" IconName="archive" Collection="material"></IgbIcon>
                Archive
                <span slot="suffix">Ctrl+Shift+A</span>
            </IgbDropdownItem>
            <IgbDropdownItem Value="delete">
                <IgbIcon slot="prefix" IconName="delete" Collection="material"></IgbIcon>
                Delete
                <span slot="suffix">Del</span>
            </IgbDropdownItem>
        </IgbDropdownGroup>
    </IgbDropdown>

    <div class="actions">
        <IgbButton Variant="ButtonVariant.Outlined" @onclick="OnToggle">Toggle</IgbButton>
    </div>
</div>

<div class="state">Selected: @Selected</div>

@code {
