@page "/IgbDropdownComponent"
@using IgniteUI.Blazor.Controls

<PageTitle>IgbDropdownComponent</PageTitle>

<h3>IgbDropdownComponent</h3>

<div class="controls">
    <div class="control">
        <label>Placement</label>
        <div class="control-box">
            <IgbRadioGroup Alignment="ContentOrientation.Horizontal" @bind-Value="PlacementName">
                <IgbRadio Value="BottomStart">BottomStart</IgbRadio>
                <IgbRadio Value="Bottom">Bottom</IgbRadio>
                <IgbRadio Value="TopStart">TopStart</IgbRadio>
                <IgbRadio Value="Top">Top</IgbRadio>
            </IgbRadioGroup>
        </div>
    </div>

    <div class="control">
        <label>Options</label>
        <div class="control-box switches">
            <IgbSwitch @bind-Checked="Flip">Flip</IgbSwitch>
            <IgbSwitch @bind-Checked="SameWidth">Same width</IgbSwitch>
        </div>
    </div>
</div>

<div class="component-host">
    <IgbDropdown @ref="_dropdown"
                 Placement="Placement"
                 Flip="Flip"
                 SameWidth="SameWidth"
                 Change="OnChange">
        <IgbButton slot="target">Choose an action</IgbButton>
        <IgbDropdownItem Value="edit">Edit</IgbDropdownItem>
        <IgbDropdownItem Value="duplicate">Duplicate</IgbDropdownItem>
        <IgbDropdownItem Value="archive">Archive</IgbDropdownItem>
        <IgbDropdownItem Value="delete">Delete</IgbDropdownItem>
    </IgbDropdown>

    <div class="actions">
        <IgbButton Variant="ButtonVariant.Outlined" @onclick="OnToggle">Toggle</IgbButton>
    </div>
</div>

<div class="state">Selected: @Selected</div>

@code {
    /*
     * Ignite UI for Blazor - open-source (MIT) component from IgniteUI.Blazor.Lite.
     * An item template can't modify project files, so do this once per project:
     *
     * 1. Install:   dotnet add package IgniteUI.Blazor.Lite
     * 2. Register (Program.cs):   builder.Services.AddIgniteUIBlazor();
     * 3. _Imports.razor:          @using IgniteUI.Blazor.Controls
     * 4. Host page theme (index.html / App.razor / _Host.cshtml):
     *    <link href="_content/IgniteUI.Blazor/themes/light/bootstrap.css" rel="stylesheet" />
     * 5. Blazor Web App (.NET 8+): add an interactive render mode to this page,
     *    e.g. @rendermode InteractiveServer (or InteractiveWebAssembly / InteractiveAuto).
     *
     * Do not mix IgniteUI.Blazor.Lite with the licensed IgniteUI.Blazor package.
     */

    private IgbDropdown _dropdown = default!;

    private string PlacementName { get; set; } = "BottomStart";
    private PopoverPlacement Placement => Enum.Parse<PopoverPlacement>(PlacementName);

    private bool Flip { get; set; } = true;
    private bool SameWidth { get; set; }
    private string Selected { get; set; } = "(none)";

    private async Task OnToggle() => await _dropdown.ToggleAsync();

    private void OnChange(IgbDropdownItemComponentEventArgs args) => Selected = args.Detail?.Value ?? "(none)";
}
