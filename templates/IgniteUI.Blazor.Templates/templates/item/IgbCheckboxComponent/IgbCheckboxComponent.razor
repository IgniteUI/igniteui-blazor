@page "/IgbCheckboxComponent"
@using IgniteUI.Blazor.Controls

<PageTitle>IgbCheckboxComponent</PageTitle>

<h3>IgbCheckboxComponent</h3>

<div class="controls">
    <div class="control">
        <label>Label position</label>
        <div class="control-box">
            <IgbRadioGroup Alignment="ContentOrientation.Horizontal" @bind-Value="LabelPositionName">
                <IgbRadio Value="After">After</IgbRadio>
                <IgbRadio Value="Before">Before</IgbRadio>
            </IgbRadioGroup>
        </div>
    </div>

    <div class="control">
        <label>Options</label>
        <div class="control-box switches">
            <IgbSwitch @bind-Checked="Indeterminate">Indeterminate</IgbSwitch>
            <IgbSwitch @bind-Checked="Disabled">Disabled</IgbSwitch>
        </div>
    </div>
</div>

<div class="component-host">
    <IgbCheckbox @bind-Checked="Checked"
                 Indeterminate="Indeterminate"
                 LabelPosition="LabelPosition"
                 Disabled="Disabled">
        I agree to the terms
    </IgbCheckbox>
</div>

<div class="state">Checked: @Checked &nbsp;|&nbsp; Indeterminate: @Indeterminate</div>

@code {
    /*
     * Ignite UI for Blazor - open-source (MIT) component from IgniteUI.Blazor.Lite.
     * An item template can't modify project files, so do this once per project:
     *
     * 1. Install:   dotnet add package IgniteUI.Blazor.Lite
     * 2. Register (Program.cs):   builder.Services.AddIgniteUIBlazor();
     * 3. _Imports.razor:          @using IgniteUI.Blazor.Controls
     *    (optional here — this file already declares its own @using;
     *    add it to _Imports.razor to share it project-wide)
     * 4. Host page theme (index.html / App.razor / _Host.cshtml):
     *    <link href="_content/IgniteUI.Blazor/themes/light/bootstrap.css" rel="stylesheet" />
     * 5. Blazor Web App (.NET 8+): add an interactive render mode to this page,
     *    e.g. @rendermode InteractiveServer (or InteractiveWebAssembly / InteractiveAuto).
     *
     * Do not mix IgniteUI.Blazor.Lite with the licensed IgniteUI.Blazor package.
     */

    private string LabelPositionName { get; set; } = "After";
    private ToggleLabelPosition LabelPosition => Enum.Parse<ToggleLabelPosition>(LabelPositionName);

    private bool Checked { get; set; } = true;
    private bool Indeterminate { get; set; }
    private bool Disabled { get; set; }
}
