@page "/IgbTooltipComponent"
@using IgniteUI.Blazor.Controls

<PageTitle>IgbTooltipComponent</PageTitle>

<h3>IgbTooltipComponent</h3>

<div class="controls">
    <div class="control">
        <label>Placement</label>
        <div class="control-box">
            <IgbRadioGroup Alignment="ContentOrientation.Horizontal" @bind-Value="PlacementName">
                <IgbRadio Value="Top">Top</IgbRadio>
                <IgbRadio Value="Bottom">Bottom</IgbRadio>
                <IgbRadio Value="Left">Left</IgbRadio>
                <IgbRadio Value="Right">Right</IgbRadio>
            </IgbRadioGroup>
        </div>
    </div>

    <div class="control">
        <label>Offset: @Offset px</label>
        <div class="control-box">
            <IgbSlider class="value-slider" @bind-Value="Offset" Min="0" Max="24" Step="2" />
        </div>
    </div>

    <div class="control">
        <label>Options</label>
        <div class="control-box switches">
            <IgbSwitch @bind-Checked="ShowTip">Show</IgbSwitch>
            <IgbSwitch @bind-Checked="WithArrow">With arrow</IgbSwitch>
            <IgbSwitch @bind-Checked="Sticky">Sticky</IgbSwitch>
        </div>
    </div>
</div>

<div class="component-host tooltip-host">
    <IgbButton id="tooltip-anchor" Variant="ButtonVariant.Contained">Anchor</IgbButton>
    <IgbTooltip Anchor="tooltip-anchor"
                Open="ShowTip"
                Placement="Placement"
                Offset="Offset"
                WithArrow="WithArrow"
                Sticky="Sticky">
        Helpful hint about this button.
    </IgbTooltip>
</div>

<div class="state">Placement: @PlacementName &nbsp;|&nbsp; Offset: @Offset</div>

@code {
    /*
     * Ignite UI for Blazor - open-source (MIT) component from IgniteUI.Blazor.Lite.
     * An item template can't modify project files, so do this once per project:
     *
     * 1. Install:   dotnet add package IgniteUI.Blazor.Lite
     * 2. Register (Program.cs):   builder.Services.AddIgniteUIBlazor();
     * 3. _Imports.razor:          @using IgniteUI.Blazor.Controls
     * 4. Host page theme (index.html / App.razor / _Host.cshtml):
     *    <link href="_content/IgniteUI.Blazor/themes/light/bootstrap.css" rel="stylesheet" />
     * 5. Blazor Web App (.NET 8+): add an interactive render mode to this page,
     *    e.g. @rendermode InteractiveServer (or InteractiveWebAssembly / InteractiveAuto).
     *
     * Do not mix IgniteUI.Blazor.Lite with the licensed IgniteUI.Blazor package.
     */

    private string PlacementName { get; set; } = "Top";
    private PopoverPlacement Placement => Enum.Parse<PopoverPlacement>(PlacementName);

    private double Offset { get; set; } = 6;
    private bool ShowTip { get; set; } = true;
    private bool WithArrow { get; set; } = true;
    private bool Sticky { get; set; } = true;
}
