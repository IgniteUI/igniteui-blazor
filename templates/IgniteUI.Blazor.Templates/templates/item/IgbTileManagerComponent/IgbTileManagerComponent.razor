@page "/IgbTileManagerComponent"
@using IgniteUI.Blazor.Controls

<PageTitle>IgbTileManagerComponent</PageTitle>

<h3>IgbTileManagerComponent</h3>

<div class="component-host">
    <IgbTileManager ColumnCount="3" Gap="16px">
        <IgbTile>
            <h3 slot="title">Tile one</h3>
            <div>Content for the first tile.</div>
        </IgbTile>
        <IgbTile>
            <h3 slot="title">Tile two</h3>
            <div>Content for the second tile.</div>
        </IgbTile>
        <IgbTile ColSpan="2">
            <h3 slot="title">Tile three</h3>
            <div>This tile spans two columns.</div>
        </IgbTile>
    </IgbTileManager>
</div>

@code {
