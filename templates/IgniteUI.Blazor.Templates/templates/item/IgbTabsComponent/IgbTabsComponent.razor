@page "/IgbTabsComponent"
@using IgniteUI.Blazor.Controls

<PageTitle>IgbTabsComponent</PageTitle>

<h3>IgbTabsComponent</h3>

<div class="component-host">
    <IgbTabs>
        <IgbTab>
            <span slot="label">Home</span>
            Home tab panel
