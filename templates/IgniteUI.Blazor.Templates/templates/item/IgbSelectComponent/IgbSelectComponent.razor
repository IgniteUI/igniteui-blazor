@page "/IgbSelectComponent"
@using IgniteUI.Blazor.Controls

<PageTitle>IgbSelectComponent</PageTitle>

<h3>IgbSelectComponent</h3>

<div class="controls">
    <div class="control">
        <label>Placement</label>
        <div class="control-box">
            <IgbRadioGroup Alignment="ContentOrientation.Horizontal" @bind-Value="PlacementName">
                <IgbRadio Value="Bottom">Bottom</IgbRadio>
                <IgbRadio Value="Top">Top</IgbRadio>
            </IgbRadioGroup>
        </div>
    </div>

    <div class="control">
        <label>Options</label>
        <div class="control-box switches">
            <IgbSwitch @bind-Checked="Outlined">Outlined</IgbSwitch>
            <IgbSwitch @bind-Checked="Disabled">Disabled</IgbSwitch>
        </div>
    </div>
</div>

<div class="component-host">
    <IgbSelect @ref="_select"
               class="demo-select"
               @bind-Value="Selected"
               Placement="Placement"
               Outlined="Outlined"
               Disabled="Disabled"
               Label="Fruit">
        <IgbSelectItem Value="orange">Orange</IgbSelectItem>
        <IgbSelectItem Value="apple">Apple</IgbSelectItem>
        <IgbSelectItem Value="banana">Banana</IgbSelectItem>
        <IgbSelectItem Value="grape" Disabled="true">Grape (out of stock)</IgbSelectItem>
    </IgbSelect>

    <div class="actions">
        <IgbButton Variant="ButtonVariant.Outlined" @onclick="OnClear">Clear</IgbButton>
    </div>
</div>

<div class="state">Selected: @(Selected ?? "(none)")</div>

@code {
    /*
     * Ignite UI for Blazor - open-source (MIT) component from IgniteUI.Blazor.Lite.
     * An item template can't modify project files, so do this once per project:
     *
     * 1. Install:   dotnet add package IgniteUI.Blazor.Lite
     * 2. Register (Program.cs):   builder.Services.AddIgniteUIBlazor();
     * 3. _Imports.razor:          @using IgniteUI.Blazor.Controls
     * 4. Host page theme (index.html / App.razor / _Host.cshtml):
     *    <link href="_content/IgniteUI.Blazor/themes/light/bootstrap.css" rel="stylesheet" />
     * 5. Blazor Web App (.NET 8+): add an interactive render mode to this page,
     *    e.g. @rendermode InteractiveServer (or InteractiveWebAssembly / InteractiveAuto).
     *
     * Do not mix IgniteUI.Blazor.Lite with the licensed IgniteUI.Blazor package.
     */

    private IgbSelect _select = default!;

    private string? Selected { get; set; }

    private string PlacementName { get; set; } = "Bottom";
    private PopoverPlacement Placement => Enum.Parse<PopoverPlacement>(PlacementName);

    private bool Outlined { get; set; }
    private bool Disabled { get; set; }

    private async Task OnClear() => await _select.ClearSelectionAsync();
}
