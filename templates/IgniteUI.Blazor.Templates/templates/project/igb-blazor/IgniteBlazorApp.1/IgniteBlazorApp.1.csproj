<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace Condition="'$(name)' != '$(name{-VALUE-FORMS-}safe_namespace)'">IgniteBlazorApp._1</RootNamespace>
    <AssemblyName Condition="'$(name)' != '$(name{-VALUE-FORMS-}safe_namespace)'">$(AssemblyName.Replace(' ', '_'))</AssemblyName>
    <BlazorDisableThrowNavigationException>true</BlazorDisableThrowNavigationException>
  </PropertyGroup>

  <ItemGroup>
    <!--#if (HostingIsServer) -->
    <PackageReference Include="IgniteUI.Blazor.Lite" Version="0.1.0" />
    <!--#if (IncludeWeatherSample) -->
    <PackageReference Include="Blazor-ApexCharts" Version="6.1.0" />
    <PackageReference Include="IgniteUI.Blazor.GridLite" Version="0.9.0" />
    <!--#endif -->
    <!--#endif -->
    <!--#if (HostingHasClient) -->
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.Server" Version="10.0.7" />
    <!--#endif -->
  </ItemGroup>

  <!--#if (HostingHasClient) -->
  <ItemGroup>
    <ProjectReference Include="..\IgniteBlazorApp.1.Client\IgniteBlazorApp.1.Client.csproj" />
  </ItemGroup>
  <!--#endif -->

</Project>
