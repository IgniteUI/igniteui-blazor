@page "/IgbCardComponent"
@using IgniteUI.Blazor.Controls

<PageTitle>IgbCardComponent</PageTitle>

<h3>IgbCardComponent</h3>

<div class="component-host">
    <IgbCard style="max-width: 20rem;">
        <IgbCardMedia Height="10rem">
            <img src="https://images.unsplash.com/photo-1518235506717-e1ed3306a89b?auto=format&fit=crop&w=640&q=50" />
        </IgbCardMedia>
        <IgbCardHeader>
            <h3 slot="title">New York City</h3>
            <h5 slot="subtitle">City in New York</h5>
        </IgbCardHeader>
        <IgbCardContent>
            <p>New York City comprises 5 boroughs sitting where the Hudson River meets the Atlantic Ocean.</p>
        </IgbCardContent>
        <IgbCardActions>
            <IgbButton slot="start">Read more</IgbButton>
        </IgbCardActions>
    </IgbCard>
</div>

@code {
    /*
