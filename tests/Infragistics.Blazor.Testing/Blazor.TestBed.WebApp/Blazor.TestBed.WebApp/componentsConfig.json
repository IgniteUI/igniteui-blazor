      "AdvancedFilteringExpressionsTree",
      // complex object
      "ResourceStrings",
      // complex object
      "Outlet",
      // stategies are not supported ATM
      "FilterStrategy",
      "DataCloneStrategy",
      "GroupStrategy",
      "SortStrategy",
      "Strategy",
      // circular ref for groupby record obj
      "GroupParent",
      "Groups",
      "Detail",
      "Parent"
    ],
    "DependantProps": [
      // summary height cannot be set without setting summaries first
      "SummaryRowHeight",
      // grouping cannot be set runtime if there's no mathing column field
      "GroupingExpressions",
      // depends on having visible columns
      "RowDraggable"
    ],
    "DependantMethods": [
      // these depend on there being groups to select/deselect/toggle
      "SelectRowsInGroupAsync",
