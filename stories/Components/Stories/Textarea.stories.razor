@attribute [Stories("Forms/Textarea")]

<Stories TComponent="IgbTextarea">

    <ArgType For="_ => _!.Resize" Control="ControlType.Radio" />

    <Story Name="Default">
        <Arguments>
            <Arg For="_ => _!.Label" Value='"Description"' />
            <Arg For="_ => _!.Placeholder" Value='"Enter description..."' />
            <Arg For="_ => _!.Rows" Value="4" />
            <Arg For="_ => _!.Outlined" Value="false" />
            <Arg For="_ => _!.Disabled" Value="false" />
        </Arguments>
        <Template>
            <IgbTextarea @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Outlined">
        <Arguments>
            <Arg For="_ => _!.Label" Value='"Notes"' />
            <Arg For="_ => _!.Outlined" Value="true" />
            <Arg For="_ => _!.Rows" Value="4" />
        </Arguments>
        <Template>
            <IgbTextarea @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Non-Resizable">
        <Arguments>
            <Arg For="_ => _!.Label" Value='"Fixed Size"' />
            <Arg For="_ => _!.Resize" Value="TextareaResize.None" />
            <Arg For="_ => _!.Rows" Value="4" />
        </Arguments>
        <Template>
            <IgbTextarea @attributes="context.Args" />
        </Template>
    </Story>

</Stories>
