@attribute [Stories("Forms/DatePicker")]

<Stories TComponent="IgbDatePicker">

    <ArgType For="_ => _!.Mode" Control="ControlType.Radio" />
    <ArgType For="_ => _!.HeaderOrientation" Control="ControlType.Radio" />

    <Story Name="Default">
        <Arguments>
            <Arg For="_ => _!.Label" Value='"Date"' />
            <Arg For="_ => _!.Mode" Value="PickerMode.Dropdown" />
            <Arg For="_ => _!.Outlined" Value="false" />
            <Arg For="_ => _!.Disabled" Value="false" />
        </Arguments>
        <Template>
            <IgbDatePicker @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Dialog Mode">
        <Arguments>
            <Arg For="_ => _!.Label" Value='"Select Date"' />
            <Arg For="_ => _!.Mode" Value="PickerMode.Dialog" />
        </Arguments>
        <Template>
            <IgbDatePicker @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Outlined">
        <Arguments>
            <Arg For="_ => _!.Label" Value='"Date"' />
            <Arg For="_ => _!.Outlined" Value="true" />
        </Arguments>
        <Template>
            <IgbDatePicker @attributes="context.Args" />
        </Template>
    </Story>

</Stories>
