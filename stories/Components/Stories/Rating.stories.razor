@attribute [Stories("Forms/Rating")]

<Stories TComponent="IgbRating">

    <Story Name="Default">
        <Arguments>
            <Arg For="_ => _!.Value" Value="3" />
            <Arg For="_ => _!.Max" Value="5" />
            <Arg For="_ => _!.Step" Value="1" />
            <Arg For="_ => _!.ReadOnly" Value="false" />
            <Arg For="_ => _!.Disabled" Value="false" />
            <Arg For="_ => _!.HoverPreview" Value="true" />
            <Arg For="_ => _!.AllowReset" Value="true" />
            <Arg For="_ => _!.Label" Value='"Rate this"' />
        </Arguments>
        <Template>
            <IgbRating @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Read Only">
        <Arguments>
            <Arg For="_ => _!.Value" Value="4" />
            <Arg For="_ => _!.Max" Value="5" />
            <Arg For="_ => _!.ReadOnly" Value="true" />
        </Arguments>
        <Template>
            <IgbRating @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Single Selection">
        <Arguments>
            <Arg For="_ => _!.Value" Value="3" />
            <Arg For="_ => _!.Max" Value="5" />
            <Arg For="_ => _!.Single" Value="true" />
        </Arguments>
        <Template>
            <IgbRating @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Disabled">
        <Arguments>
            <Arg For="_ => _!.Value" Value="2" />
            <Arg For="_ => _!.Max" Value="5" />
            <Arg For="_ => _!.Disabled" Value="true" />
        </Arguments>
        <Template>
            <IgbRating @attributes="context.Args" />
        </Template>
    </Story>

</Stories>
