@attribute [Stories("Forms/DateRangePicker")]

<Stories TComponent="IgbDateRangePicker">

    <ArgType For="_ => _!.Mode" Control="ControlType.Radio" />

    <Story Name="Default">
        <Arguments>
            <Arg For="_ => _!.Label" Value='"Date Range"' />
            <Arg For="_ => _!.Mode" Value="PickerMode.Dropdown" />
            <Arg For="_ => _!.Outlined" Value="false" />
        </Arguments>
        <Template>
            <IgbDateRangePicker @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Two Inputs">
        <Arguments>
            <Arg For="_ => _!.LabelStart" Value='"Start Date"' />
            <Arg For="_ => _!.LabelEnd" Value='"End Date"' />
            <Arg For="_ => _!.UseTwoInputs" Value="true" />
        </Arguments>
        <Template>
            <IgbDateRangePicker @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Dialog Mode">
        <Arguments>
            <Arg For="_ => _!.Label" Value='"Date Range"' />
            <Arg For="_ => _!.Mode" Value="PickerMode.Dialog" />
        </Arguments>
        <Template>
            <IgbDateRangePicker @attributes="context.Args" />
        </Template>
    </Story>

</Stories>
