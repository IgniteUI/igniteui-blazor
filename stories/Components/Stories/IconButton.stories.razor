@attribute [Stories("Actions/IconButton")]

<Stories TComponent="IgbIconButton">

    <ArgType For="_ => _!.Variant" Control="ControlType.Radio" />

    <Story Name="Default">
        <Arguments>
            <Arg For="_ => _!.Variant" Value="IconButtonVariant.Contained" />
            <Arg For="_ => _!.IconName" Value='"home"' />
            <Arg For="_ => _!.Collection" Value='"default"' />
            <Arg For="_ => _!.Disabled" Value="false" />
        </Arguments>
        <Template>
            <IconRegistrar />
            <IgbIconButton @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Outlined">
        <Arguments>
            <Arg For="_ => _!.Variant" Value="IconButtonVariant.Outlined" />
            <Arg For="_ => _!.IconName" Value='"home"' />
            <Arg For="_ => _!.Collection" Value='"default"' />
        </Arguments>
        <Template>
            <IconRegistrar />
            <IgbIconButton @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Flat">
        <Arguments>
            <Arg For="_ => _!.Variant" Value="IconButtonVariant.Flat" />
            <Arg For="_ => _!.IconName" Value='"home"' />
            <Arg For="_ => _!.Collection" Value='"default"' />
        </Arguments>
        <Template>
            <IconRegistrar />
            <IgbIconButton @attributes="context.Args" />
        </Template>
    </Story>

</Stories>
