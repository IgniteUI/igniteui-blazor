@attribute [Stories("Feedback/CircularProgress")]

<Stories TComponent="IgbCircularProgress">

    <ArgType For="_ => _!.Variant" Control="ControlType.Radio" />

    <Story Name="Default">
        <Arguments>
            <Arg For="_ => _!.Value" Value="65" />
            <Arg For="_ => _!.Max" Value="100" />
            <Arg For="_ => _!.Variant" Value="StyleVariant.Primary" />
            <Arg For="_ => _!.Indeterminate" Value="false" />
            <Arg For="_ => _!.HideLabel" Value="false" />
        </Arguments>
        <Template>
            <IgbCircularProgress @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Indeterminate">
        <Arguments>
            <Arg For="_ => _!.Indeterminate" Value="true" />
        </Arguments>
        <Template>
            <IgbCircularProgress @attributes="context.Args" />
        </Template>
    </Story>

</Stories>
