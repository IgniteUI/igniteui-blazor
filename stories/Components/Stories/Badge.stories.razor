@attribute [Stories("Data Display/Badge")]

<Stories TComponent="IgbBadge">

    <ArgType For="_ => _!.Variant" Control="ControlType.Radio" />
    <ArgType For="_ => _!.Shape" Control="ControlType.Radio" />

    <Story Name="Default">
        <Arguments>
            <Arg For="_ => _!.Variant" Value="StyleVariant.Primary" />
            <Arg For="_ => _!.Shape" Value="BadgeShape.Rounded" />
            <Arg For="_ => _!.Outlined" Value="false" />
            <Arg For="_ => _!.ChildContent" Value="_content" />
        </Arguments>
        <Template>
            <IgbBadge @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Outlined">
        <Arguments>
            <Arg For="_ => _!.Outlined" Value="true" />
            <Arg For="_ => _!.ChildContent" Value="_content" />
        </Arguments>
        <Template>
            <IgbBadge @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Square">
        <Arguments>
            <Arg For="_ => _!.Shape" Value="BadgeShape.Square" />
            <Arg For="_ => _!.ChildContent" Value="_content" />
        </Arguments>
        <Template>
            <IgbBadge @attributes="context.Args" />
        </Template>
    </Story>

</Stories>

@code {
    private RenderFragment _content = @<text>1</text>;
}
