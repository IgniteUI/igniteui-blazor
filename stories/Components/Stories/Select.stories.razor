@attribute [Stories("Forms/Select")]

<Stories TComponent="IgbSelect">

    <ArgType For="_ => _!.Placement" Control="ControlType.Select" />

    <Story Name="Default">
        <Arguments>
            <Arg For="_ => _!.Label" Value='"Country"' />
            <Arg For="_ => _!.Placeholder" Value='"Select a country"' />
            <Arg For="_ => _!.Outlined" Value="false" />
            <Arg For="_ => _!.Disabled" Value="false" />
        </Arguments>
        <Template>
            <IgbSelect @attributes="context.Args">
                <IgbSelectItem Value="us">United States</IgbSelectItem>
                <IgbSelectItem Value="uk">United Kingdom</IgbSelectItem>
                <IgbSelectItem Value="de">Germany</IgbSelectItem>
                <IgbSelectItem Value="fr">France</IgbSelectItem>
                <IgbSelectItem Value="jp">Japan</IgbSelectItem>
            </IgbSelect>
        </Template>
    </Story>

    <Story Name="Outlined">
        <Arguments>
            <Arg For="_ => _!.Label" Value='"Country"' />
            <Arg For="_ => _!.Outlined" Value="true" />
        </Arguments>
        <Template>
            <IgbSelect @attributes="context.Args">
                <IgbSelectItem Value="us">United States</IgbSelectItem>
                <IgbSelectItem Value="uk">United Kingdom</IgbSelectItem>
                <IgbSelectItem Value="de">Germany</IgbSelectItem>
                <IgbSelectItem Value="fr">France</IgbSelectItem>
                <IgbSelectItem Value="jp">Japan</IgbSelectItem>
            </IgbSelect>
        </Template>
    </Story>

    <Story Name="Disabled">
        <Arguments>
            <Arg For="_ => _!.Disabled" Value="true" />
            <Arg For="_ => _!.Label" Value='"Disabled"' />
        </Arguments>
        <Template>
            <IgbSelect @attributes="context.Args">
                <IgbSelectItem Value="us">United States</IgbSelectItem>
                <IgbSelectItem Value="uk">United Kingdom</IgbSelectItem>
                <IgbSelectItem Value="de">Germany</IgbSelectItem>
                <IgbSelectItem Value="fr">France</IgbSelectItem>
                <IgbSelectItem Value="jp">Japan</IgbSelectItem>
            </IgbSelect>
        </Template>
    </Story>

</Stories>
