@attribute [Stories("Layout/ExpansionPanel")]

<Stories TComponent="IgbExpansionPanel">

    <ArgType For="_ => _!.IndicatorPosition" Control="ControlType.Radio" />

    <Story Name="Default">
        <Arguments>
            <Arg For="_ => _!.Open" Value="false" />
            <Arg For="_ => _!.Disabled" Value="false" />
            <Arg For="_ => _!.IndicatorPosition" Value="ExpansionPanelIndicatorPosition.Start" />
            <Arg For="_ => _!.ChildContent" Value="_content" />
        </Arguments>
        <Template>
            <IgbExpansionPanel @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Open">
        <Arguments>
            <Arg For="_ => _!.Open" Value="true" />
            <Arg For="_ => _!.ChildContent" Value="_content" />
        </Arguments>
        <Template>
            <IgbExpansionPanel @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Disabled">
        <Arguments>
            <Arg For="_ => _!.Disabled" Value="true" />
            <Arg For="_ => _!.ChildContent" Value="_content" />
        </Arguments>
        <Template>
            <IgbExpansionPanel @attributes="context.Args" />
        </Template>
    </Story>

</Stories>

@code {
    private RenderFragment _content = @<text>
        <span slot="title">Expansion Panel Title</span>
        <p>This is the content of the expansion panel. It can contain any markup.</p>
    </text>;
}
