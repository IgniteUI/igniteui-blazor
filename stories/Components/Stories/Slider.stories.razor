@attribute [Stories("Forms/Slider")]

<Stories TComponent="IgbSlider">

    <ArgType For="_ => _!.TickOrientation" Control="ControlType.Radio" />

    <Story Name="Default">
        <Arguments>
            <Arg For="_ => _!.Value" Value="50" />
            <Arg For="_ => _!.Min" Value="0" />
            <Arg For="_ => _!.Max" Value="100" />
            <Arg For="_ => _!.Step" Value="1" />
            <Arg For="_ => _!.Disabled" Value="false" />
        </Arguments>
        <Template>
            <div style="width: 300px; padding: 20px;">
                <IgbSlider @attributes="context.Args" />
            </div>
        </Template>
    </Story>

    <Story Name="With Ticks">
        <Arguments>
            <Arg For="_ => _!.Value" Value="50" />
            <Arg For="_ => _!.Min" Value="0" />
            <Arg For="_ => _!.Max" Value="100" />
            <Arg For="_ => _!.Step" Value="10" />
            <Arg For="_ => _!.DiscreteTrack" Value="true" />
            <Arg For="_ => _!.PrimaryTicks" Value="5" />
            <Arg For="_ => _!.SecondaryTicks" Value="2" />
        </Arguments>
        <Template>
            <div style="width: 300px; padding: 20px;">
                <IgbSlider @attributes="context.Args" />
            </div>
        </Template>
    </Story>

    <Story Name="Disabled">
        <Arguments>
            <Arg For="_ => _!.Value" Value="30" />
            <Arg For="_ => _!.Disabled" Value="true" />
        </Arguments>
        <Template>
            <div style="width: 300px; padding: 20px;">
                <IgbSlider @attributes="context.Args" />
            </div>
        </Template>
    </Story>

</Stories>
