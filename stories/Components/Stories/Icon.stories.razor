@attribute [Stories("Data Display/Icon")]

<Stories TComponent="IgbIcon">

    <Story Name="Default">
        <Arguments>
            <Arg For="_ => _!.IconName" Value='"home"' />
            <Arg For="_ => _!.Collection" Value='"default"' />
            <Arg For="_ => _!.Mirrored" Value="false" />
        </Arguments>
        <Template>
            <IconRegistrar />
            <IgbIcon @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Mirrored">
        <Arguments>
            <Arg For="_ => _!.IconName" Value='"home"' />
            <Arg For="_ => _!.Collection" Value='"default"' />
            <Arg For="_ => _!.Mirrored" Value="true" />
        </Arguments>
        <Template>
            <IconRegistrar />
            <IgbIcon @attributes="context.Args" />
        </Template>
    </Story>

</Stories>
