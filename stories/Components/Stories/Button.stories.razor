@attribute [Stories("Actions/Button")]

<Stories TComponent="IgbButton">

    <ArgType For="_ => _!.Variant" Control="ControlType.Radio" />
    <ArgType For="_ => _!.DisplayType" Control="ControlType.Radio" />

    <Story Name="Default">
        <Arguments>
            <Arg For="_ => _!.Variant" Value="ButtonVariant.Contained" />
            <Arg For="_ => _!.Disabled" Value="false" />
            <Arg For="_ => _!.ChildContent" Value="_content" />
        </Arguments>
        <Template>
            <IgbButton @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Outlined">
        <Arguments>
            <Arg For="_ => _!.Variant" Value="ButtonVariant.Outlined" />
            <Arg For="_ => _!.ChildContent" Value="_content" />
        </Arguments>
        <Template>
            <IgbButton @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Flat">
        <Arguments>
            <Arg For="_ => _!.Variant" Value="ButtonVariant.Flat" />
            <Arg For="_ => _!.ChildContent" Value="_content" />
        </Arguments>
        <Template>
            <IgbButton @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Disabled">
        <Arguments>
            <Arg For="_ => _!.Variant" Value="ButtonVariant.Contained" />
            <Arg For="_ => _!.Disabled" Value="true" />
            <Arg For="_ => _!.ChildContent" Value="_content" />
        </Arguments>
        <Template>
            <IgbButton @attributes="context.Args" />
        </Template>
    </Story>

</Stories>

@code {
    private RenderFragment _content = @<text>Click Me</text>;
}