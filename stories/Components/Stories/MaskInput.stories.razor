@attribute [Stories("Forms/MaskInput")]

<Stories TComponent="IgbMaskInput">

    <ArgType For="_ => _!.ValueMode" Control="ControlType.Radio" />

    <Story Name="Default">
        <Arguments>
            <Arg For="_ => _!.Mask" Value='"(000) 000-0000"' />
            <Arg For="_ => _!.Label" Value='"Phone Number"' />
            <Arg For="_ => _!.Placeholder" Value='"(___) ___-____"' />
        </Arguments>
        <Template>
            <IgbMaskInput @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Social Security">
        <Arguments>
            <Arg For="_ => _!.Mask" Value='"000-00-0000"' />
            <Arg For="_ => _!.Label" Value='"SSN"' />
        </Arguments>
        <Template>
            <IgbMaskInput @attributes="context.Args" />
        </Template>
    </Story>

</Stories>
