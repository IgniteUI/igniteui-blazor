@attribute [Stories("Actions/ButtonGroup")]

<Stories TComponent="IgbButtonGroup">

    <ArgType For="_ => _!.Selection" Control="ControlType.Radio" />
    <ArgType For="_ => _!.Alignment" Control="ControlType.Radio" />

    <Story Name="Default">
        <Arguments>
            <Arg For="_ => _!.Selection" Value="ButtonGroupSelection.Single" />
            <Arg For="_ => _!.Disabled" Value="false" />
        </Arguments>
        <Template>
            <IgbButtonGroup @attributes="context.Args">
                <IgbToggleButton>Bold</IgbToggleButton>
                <IgbToggleButton>Italic</IgbToggleButton>
                <IgbToggleButton>Underline</IgbToggleButton>
            </IgbButtonGroup>
        </Template>
    </Story>

    <Story Name="Multiple Selection">
        <Arguments>
            <Arg For="_ => _!.Selection" Value="ButtonGroupSelection.Multiple" />
        </Arguments>
        <Template>
            <IgbButtonGroup @attributes="context.Args">
                <IgbToggleButton>Bold</IgbToggleButton>
                <IgbToggleButton>Italic</IgbToggleButton>
                <IgbToggleButton>Underline</IgbToggleButton>
            </IgbButtonGroup>
        </Template>
    </Story>

    <Story Name="Disabled">
        <Arguments>
            <Arg For="_ => _!.Disabled" Value="true" />
        </Arguments>
        <Template>
            <IgbButtonGroup @attributes="context.Args">
                <IgbToggleButton>Bold</IgbToggleButton>
                <IgbToggleButton>Italic</IgbToggleButton>
                <IgbToggleButton>Underline</IgbToggleButton>
            </IgbButtonGroup>
        </Template>
    </Story>

</Stories>
