@* Renders a hidden IgbIcon and registers common Material Design icons on first render. *@
@* Include this component in story templates that use IgbIcon or IgbIconButton. *@
<IgbIcon @ref="_icon" style="display: none;" />

@code {
    private IgbIcon? _icon;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _icon is not null)
        {
            await _icon.EnsureReady();
            await _icon.RegisterIconFromTextAsync("home", HomeSvg, "default");
            await _icon.RegisterIconFromTextAsync("search", SearchSvg, "default");
            await _icon.RegisterIconFromTextAsync("favorite", FavoriteSvg, "default");
            await _icon.RegisterIconFromTextAsync("settings", SettingsSvg, "default");
            await _icon.RegisterIconFromTextAsync("delete", DeleteSvg, "default");
            await _icon.RegisterIconFromTextAsync("menu", MenuSvg, "default");
        }
    }

    private const string HomeSvg =
        """<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>""";

